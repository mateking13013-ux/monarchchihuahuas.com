import PuppyCard from '../components/PuppyCard.astro';
import TestimonialsPreview from '../components/TestimonialsPreview.astro';
import ContactPopup from '../components/ContactPopup.astro';
---

<BaseLayout
  title="Available Puppies | Monarch Chihuahuas"
  description="Browse our available Chihuahua puppies. Find your perfect tiny companion today. Health guaranteed, vet checked, and ready for their forever homes."
  keywords="Chihuahua puppies for sale, available puppies, teacup chihuahuas, chihuahua puppies"
  ogTitle="Available Puppies | Monarch Chihuahuas"
  ogDescription="Browse our adorable Chihuahua puppies available for adoption. Health guaranteed, vet checked, and ready for their forever homes."
>
  <PageHeader
    title="Available Puppies"
    subtitle="Find your perfect Chihuahua companion from our adorable puppies"
  />
  <PuppyCard />
  <TestimonialsPreview />
  <ContactPopup />
</BaseLayout>
