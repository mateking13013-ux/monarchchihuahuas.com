---
// MainHeader component - Main navigation
---

<header class="header">
  <div class="header-container">
    <a href="/" class="logo" aria-label="Healthy Staffords — home">
      <span class="logo-mark"><i class="fa-solid fa-paw" aria-hidden="true"></i></span>
      <span class="logo-word">
        <span class="logo-word-top">Healthy</span>
        <span class="logo-word-bot">Staffords</span>
      </span>
    </a>

    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="nav-overlay"></div>

    <nav class="nav-menu">
      <div class="nav-brand-mobile">
        <span class="logo-mark logo-mark-sm"><i class="fa-solid fa-paw" aria-hidden="true"></i></span>
        <span class="logo-word">
          <span class="logo-word-top">Healthy</span>
          <span class="logo-word-bot">Staffords</span>
        </span>
      </div>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/available-puppies">Available Puppies</a></li>
        <li><a href="/about-us">About Us</a></li>
        <li><a href="/testimonials">Testimonials</a></li>
        <li><a href="/faqs">FAQs</a></li>
        <li><a href="/health-guarantee">Health Guarantee</a></li>
        <li><a href="/vaccinations">Vaccinations</a></li>
        <li><a href="/pickup-delivery">Pickup & Delivery</a></li>
      </ul>
      <a href="/contact" class="nav-cta-mobile">Get a Puppy</a>
    </nav>

    <a href="/contact" class="header-cta">Get a Puppy</a>
  </div>
</header>

<script>
  const menuToggle = document.querySelector('.menu-toggle');
  const nav = document.querySelector('.nav-menu');
  const overlay = document.querySelector('.nav-overlay');

  let isMenuOpen = false;

  menuToggle?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    nav?.classList.toggle('active', isMenuOpen);
    overlay?.classList.toggle('active', isMenuOpen);
    menuToggle?.classList.toggle('active', isMenuOpen);
    menuToggle?.setAttribute('aria-expanded', String(isMenuOpen));
  });

  overlay?.addEventListener('click', () => {
    isMenuOpen = false;
    nav?.classList.remove('active');
    overlay?.classList.remove('active');
    menuToggle?.classList.remove('active');
    menuToggle?.setAttribute('aria-expanded', 'false');
  });
</script>

<style>
  .header {
    display: block;
    font-family: var(--font-family);
    background: var(--color-off-white);
    border-bottom: 1px solid var(--color-gray-200);
    box-shadow: 0 1px 0 rgba(74, 43, 20, 0.03);
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  .header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.875rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    flex-shrink: 0;
    color: var(--color-gray-900);
    line-height: 1;
  }

  .logo-mark {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-cream);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    box-shadow: 0 6px 14px rgba(107, 63, 29, 0.28);
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .logo:hover .logo-mark {
    background: var(--color-secondary);
    transform: rotate(-8deg);
  }

  .logo-mark-sm {
    width: 38px;
    height: 38px;
    font-size: 1.05rem;
  }

  .logo-word {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    font-family: var(--font-serif);
    letter-spacing: -0.01em;
  }

  .logo-word-top {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-secondary);
    font-family: var(--font-family);
  }

  .logo-word-bot {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-gray-900);
    font-family: var(--font-serif);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    flex: 1;
    justify-content: center;
  }

  .nav-brand-mobile {
    display: none;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-gray-200);
  }

  .nav-cta-mobile {
    display: none;
  }

  .nav-menu > ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2rem;
  }

  .nav-menu a {
    text-decoration: none;
    color: var(--color-gray-700);
    font-weight: 500;
    font-size: 0.92rem;
    letter-spacing: 0.01em;
    transition: color 0.25s ease;
    position: relative;
    padding: 0.5rem 0;
  }

  .nav-menu > ul > li > a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1.5px;
    background: var(--color-secondary);
    transition: width 0.3s ease;
  }

  .nav-menu a:hover {
    color: var(--color-primary);
  }

  .nav-menu > ul > li > a:hover::after {
    width: 100%;
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: var(--color-cream);
    padding: 0.78rem 1.6rem;
    border-radius: 999px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: all 0.3s ease;
    flex-shrink: 0;
    white-space: nowrap;
    box-shadow: 0 6px 16px rgba(107, 63, 29, 0.22);
  }

  .header-cta:hover {
    background: var(--color-primary-dark);
    transform: translateY(-2px);
    box-shadow: 0 10px 22px rgba(107, 63, 29, 0.3);
    color: var(--color-cream);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 101;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2.5px;
    background: var(--color-primary);
    border-radius: 3px;
    transition: all 0.3s ease;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(6px, -6px);
  }

  .nav-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    z-index: 98;
    backdrop-filter: blur(2px);
  }

  .nav-overlay.active {
    display: block;
  }

  @media (max-width: 1100px) {
    .nav-menu > ul {
      gap: 1.5rem;
    }

    .header-container {
      gap: 1.5rem;
    }
  }

  @media (max-width: 900px) {
    .menu-toggle {
      display: flex;
    }

    .header-container {
      padding: 0.875rem 1.5rem;
    }

    .nav-menu {
      position: fixed;
      top: 0;
      right: -100%;
      width: 300px;
      height: 100vh;
      background: white;
      flex-direction: column;
      padding: 2rem;
      box-shadow: -5px 0 30px rgba(0, 0, 0, 0.1);
      transition: right 0.3s ease;
      z-index: 99;
      justify-content: flex-start;
      align-items: flex-start;
    }

    .nav-menu.active {
      right: 0;
    }

    .nav-brand-mobile {
      display: flex;
      width: 100%;
    }

    .nav-cta-mobile {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--color-primary);
      color: var(--color-cream);
      padding: 0.75rem 1.5rem;
      border-radius: 999px;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      margin-top: 1.5rem;
      width: 100%;
      text-align: center;
    }

    .nav-menu > ul {
      flex-direction: column;
      gap: 0.25rem;
      width: 100%;
      padding: 0;
    }

    .nav-menu > ul > li > a {
      display: block;
      padding: 0.6rem 0;
      font-size: 0.95rem;
    }

    .nav-menu > ul > li > a::after {
      display: none;
    }

    .header-cta {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .header-container {
      padding: 0.75rem 1rem;
    }

    .logo-mark {
      width: 38px;
      height: 38px;
      font-size: 1.05rem;
    }

    .logo-word-bot {
      font-size: 1.25rem;
    }

    .logo-word-top {
      font-size: 0.65rem;
      letter-spacing: 0.24em;
    }
  }
</style>
