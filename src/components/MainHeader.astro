---
// MainHeader component - Crown Palace Shih Tzu navigation
---

<header class="header">
  <div class="header-accent"></div>
  <div class="header-container">
    <a href="/" class="logo" aria-label="Crown Palace Shih Tzu — home">
      <span class="logo-mark"><i class="fa-solid fa-crown" aria-hidden="true"></i></span>
      <span class="logo-word">
        <span class="logo-word-top">Crown Palace</span>
        <span class="logo-word-bot">Shih Tzu</span>
      </span>
    </a>

    <button class="menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="nav-overlay"></div>

    <nav class="nav-menu">
      <div class="nav-brand-mobile">
        <span class="logo-mark logo-mark-sm"><i class="fa-solid fa-crown" aria-hidden="true"></i></span>
        <span class="logo-word">
          <span class="logo-word-top">Crown Palace</span>
          <span class="logo-word-bot">Shih Tzu</span>
        </span>
      </div>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/available-puppies">Puppies</a></li>
        <li><a href="/about-us">About</a></li>
        <li><a href="/testimonials">Testimonials</a></li>
        <li><a href="/faqs">FAQs</a></li>
        <li><a href="/health-guarantee">Guarantee</a></li>
        <li><a href="/vaccinations">Vaccinations</a></li>
        <li><a href="/pickup-delivery">Delivery</a></li>
      </ul>
      <a href="/contact" class="nav-cta-mobile">Get a Puppy</a>
    </nav>

    <a href="/contact" class="header-cta">
      <i class="fa-solid fa-crown" aria-hidden="true"></i>
      <span>Get a Puppy</span>
    </a>
  </div>
</header>

<script>
  const menuToggle = document.querySelector('.menu-toggle');
  const nav = document.querySelector('.nav-menu');
  const overlay = document.querySelector('.nav-overlay');

  let isMenuOpen = false;

  menuToggle?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    nav?.classList.toggle('active', isMenuOpen);
    overlay?.classList.toggle('active', isMenuOpen);
    menuToggle?.classList.toggle('active', isMenuOpen);
    menuToggle?.setAttribute('aria-expanded', String(isMenuOpen));
  });

  overlay?.addEventListener('click', () => {
    isMenuOpen = false;
    nav?.classList.remove('active');
    overlay?.classList.remove('active');
    menuToggle?.classList.remove('active');
    menuToggle?.setAttribute('aria-expanded', 'false');
  });
</script>

<style>
  .header {
    display: block;
    font-family: var(--font-display);
    background: linear-gradient(180deg, #ffffff 0%, var(--color-off-white) 100%);
    border-bottom: 1px solid var(--color-gray-200);
    box-shadow: 0 2px 14px rgba(74, 27, 102, 0.06);
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  .header-accent {
    height: 4px;
    background: linear-gradient(90deg,
      var(--color-primary-dark) 0%,
      var(--color-primary) 30%,
      var(--color-secondary) 60%,
      var(--color-primary) 100%);
  }

  .header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    flex-shrink: 0;
    color: var(--color-gray-900);
    line-height: 1;
  }

  .logo-mark {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: var(--color-secondary-light);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    box-shadow: 0 8px 18px rgba(74, 27, 102, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transition: transform 0.3s ease;
    border: 1.5px solid var(--color-secondary);
  }

  .logo:hover .logo-mark {
    transform: rotate(-6deg) scale(1.04);
  }

  .logo-mark-sm {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    font-size: 1.05rem;
  }

  .logo-word {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
    line-height: 1;
  }

  .logo-word-top {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--color-secondary-dark);
  }

  .logo-word-bot {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    flex: 1;
    justify-content: center;
  }

  .nav-brand-mobile {
    display: none;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--color-secondary-light);
  }

  .nav-cta-mobile {
    display: none;
  }

  .nav-menu > ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.85rem;
  }

  .nav-menu a {
    text-decoration: none;
    color: var(--color-gray-800);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 0.92rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: color 0.25s ease;
    position: relative;
    padding: 0.55rem 0;
  }

  .nav-menu > ul > li > a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 2px;
    background: var(--color-secondary);
    transition: width 0.3s ease, left 0.3s ease;
  }

  .nav-menu a:hover {
    color: var(--color-primary);
  }

  .nav-menu > ul > li > a:hover::after {
    width: 100%;
    left: 0;
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: var(--color-white);
    padding: 0.85rem 1.7rem;
    border-radius: 6px;
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    text-decoration: none;
    transition: all 0.3s ease;
    flex-shrink: 0;
    white-space: nowrap;
    box-shadow: 0 6px 16px rgba(74, 27, 102, 0.28);
    border: 1.5px solid var(--color-secondary);
  }

  .header-cta i {
    color: var(--color-secondary-light);
    font-size: 0.95rem;
  }

  .header-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 24px rgba(74, 27, 102, 0.4);
    color: var(--color-white);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 101;
  }

  .menu-toggle span {
    display: block;
    width: 26px;
    height: 3px;
    background: var(--color-primary);
    border-radius: 3px;
    transition: all 0.3s ease;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(6px, -6px);
  }

  .nav-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(23, 15, 27, 0.5);
    z-index: 98;
    backdrop-filter: blur(2px);
  }

  .nav-overlay.active {
    display: block;
  }

  @media (max-width: 1100px) {
    .nav-menu > ul {
      gap: 1.25rem;
    }

    .nav-menu a {
      font-size: 0.85rem;
      letter-spacing: 0.14em;
    }

    .header-container {
      gap: 1.5rem;
    }
  }

  @media (max-width: 900px) {
    .menu-toggle {
      display: flex;
    }

    .header-container {
      padding: 0.875rem 1.5rem;
    }

    .nav-menu {
      position: fixed;
      top: 0;
      right: -100%;
      width: 320px;
      height: 100vh;
      background: white;
      flex-direction: column;
      padding: 2rem;
      box-shadow: -5px 0 30px rgba(74, 27, 102, 0.18);
      transition: right 0.3s ease;
      z-index: 99;
      justify-content: flex-start;
      align-items: flex-start;
    }

    .nav-menu.active {
      right: 0;
    }

    .nav-brand-mobile {
      display: flex;
      width: 100%;
    }

    .nav-cta-mobile {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
      color: var(--color-white);
      padding: 0.85rem 1.5rem;
      border-radius: 6px;
      font-family: var(--font-display);
      font-size: 0.9rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.2em;
      text-decoration: none;
      margin-top: 1.5rem;
      width: 100%;
      text-align: center;
      border: 1.5px solid var(--color-secondary);
    }

    .nav-menu > ul {
      flex-direction: column;
      gap: 0.25rem;
      width: 100%;
      padding: 0;
    }

    .nav-menu > ul > li > a {
      display: block;
      padding: 0.7rem 0;
      font-size: 0.95rem;
    }

    .nav-menu > ul > li > a::after {
      display: none;
    }

    .header-cta {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .header-container {
      padding: 0.75rem 1rem;
    }

    .logo-mark {
      width: 42px;
      height: 42px;
      font-size: 1.1rem;
    }

    .logo-word-bot {
      font-size: 1.3rem;
    }

    .logo-word-top {
      font-size: 0.65rem;
      letter-spacing: 0.28em;
    }
  }
</style>
