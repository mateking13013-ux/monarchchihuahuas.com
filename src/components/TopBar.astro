---
// TopBar — slim announcement strip
---

<div class="top-bar">
  <div class="top-inner">
    <span class="message">
      <span class="dot"></span>
      Reserving spring &amp; summer litters — welcoming a few thoughtful families
    </span>
    <a href="/contact" class="btn">Schedule a call <span aria-hidden="true">&rarr;</span></a>
  </div>
</div>

<style>
  .top-bar {
    background: var(--color-gray-900);
    color: var(--color-cream);
    font-family: var(--font-family);
    border-bottom: 1px solid rgba(251, 245, 233, 0.08);
  }

  .top-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.6rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .message {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.82rem;
    font-weight: 400;
    letter-spacing: 0.01em;
    color: rgba(251, 245, 233, 0.88);
  }

  .dot {
    width: 7px;
    height: 7px;
    background: var(--color-gold);
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgba(212, 160, 85, 0.2);
    flex-shrink: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-gold);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.25s ease;
  }

  .btn:hover {
    color: var(--color-cream);
  }

  .btn span {
    transition: transform 0.25s ease;
  }

  .btn:hover span { transform: translateX(3px); }

  @media (max-width: 768px) {
    .top-inner { padding: 0.55rem 1.1rem; gap: 0.75rem; }
    .message { font-size: 0.74rem; }
    .btn { font-size: 0.68rem; }
  }

  @media (max-width: 520px) {
    .top-inner { justify-content: center; }
    .btn { display: none; }
    .message { font-size: 0.72rem; text-align: center; }
  }
</style>
