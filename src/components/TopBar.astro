---
// TopBar — slim announcement strip
---

<div class="top-bar">
  <div class="top-inner">
    <span class="message">
      <span class="dot"></span>
      Reserving spring &amp; summer litters — welcoming a few thoughtful families
    </span>
    <a href="/contact" class="btn">Schedule a call <span aria-hidden="true">&rarr;</span></a>
  </div>
</div>

<style>
  .top-bar {
    background: linear-gradient(90deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);
    color: var(--color-white);
    font-family: var(--font-family);
    border-bottom: 1px solid rgba(255, 255, 255, 0.10);
  }

  .top-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.18rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    min-height: 22px;
  }

  .message {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--color-white);
    line-height: 1;
  }

  .dot {
    width: 5px;
    height: 5px;
    background: var(--color-secondary-light);
    border-radius: 50%;
    box-shadow: 0 0 0 2px rgba(212, 178, 90, 0.28);
    flex-shrink: 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: var(--color-white);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.25s ease;
    opacity: 0.95;
    line-height: 1;
  }

  .btn:hover {
    color: var(--color-secondary-light);
    opacity: 1;
  }

  .btn span {
    transition: transform 0.25s ease;
  }

  .btn:hover span { transform: translateX(3px); }

  @media (max-width: 768px) {
    .top-inner { padding: 0.16rem 1.1rem; gap: 0.6rem; min-height: 20px; }
    .message { font-size: 0.64rem; }
    .btn { font-size: 0.6rem; }
  }

  @media (max-width: 520px) {
    .top-inner { justify-content: center; }
    .btn { display: none; }
    .message { font-size: 0.62rem; text-align: center; }
  }
</style>
