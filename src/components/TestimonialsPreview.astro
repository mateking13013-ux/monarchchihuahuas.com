---
// TestimonialsPreview — text-only review cards (no images)
import { testimonialPreviews } from '../data/testimonials';
---

<section class="testimonials-section">
  <div class="section-container">
    <div class="section-header">
      <span class="section-badge">Five-Star Reviews</span>
      <h2 class="section-title">What Our Families Say</h2>
      <p class="section-subtitle">Real stories from happy Shih Tzu families across the country.</p>
    </div>

    <div class="testimonials-masonry">
      {testimonialPreviews.map((t) => (
        <div class="testimonial-card">
          <div class="card-header">
            <div class="avatar">
              {t.initials}
              <span class="verified-badge" aria-hidden="true">
                <svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/></svg>
              </span>
            </div>
            <div class="reviewer-info">
              <h4>{t.name}</h4>
              <p class="reviewer-label">Verified Family</p>
            </div>
          </div>

          <div class="rating-row">
            <div class="stars">
              {Array(5).fill(null).map(() => (
                <svg class="star" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              ))}
            </div>
            <span class="rating-text">{t.rating}/5</span>
          </div>

          <p class="review-text">{t.text}</p>

          <p class="review-meta">{t.timeAgo} &middot; {t.location}</p>

          <div class="card-footer">
            <span class="business-name">Crown Palace Shih Tzu</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials-section {
    display: block;
    font-family: var(--font-family);
    background: var(--color-cream);
    padding: 4.5rem 1.5rem;
  }

  .section-container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--color-secondary-dark);
    margin-bottom: 0.9rem;
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.4vw, 2.75rem);
    font-weight: 600;
    color: var(--color-gray-900);
    margin: 0 0 0.6rem;
  }

  .section-subtitle {
    font-size: 1rem;
    color: var(--color-gray-600);
    margin: 0 auto;
    max-width: 560px;
  }

  .testimonials-masonry {
    columns: 3;
    column-gap: 1.5rem;
  }

  .testimonial-card {
    break-inside: avoid;
    background: var(--color-white);
    border: 1px solid var(--color-gray-200);
    border-radius: 14px;
    padding: 1.6rem 1.5rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 14px rgba(74, 27, 102, 0.06);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1rem;
  }

  .avatar {
    position: relative;
    width: 48px;
    height: 48px;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: var(--color-white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }

  .verified-badge {
    position: absolute;
    bottom: -2px;
    right: -2px;
    width: 18px;
    height: 18px;
    background: var(--color-secondary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid white;
  }

  .verified-badge svg {
    width: 10px;
    height: 10px;
    fill: white;
  }

  .reviewer-info h4 {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-gray-900);
  }

  .reviewer-label {
    font-size: 0.78rem;
    color: var(--color-secondary-dark);
    margin: 2px 0 0;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .rating-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.85rem;
  }

  .stars {
    display: flex;
    gap: 2px;
  }

  .star {
    width: 18px;
    height: 18px;
    fill: var(--color-gold);
  }

  .rating-text {
    font-size: 0.92rem;
    color: var(--color-gray-600);
    font-weight: 500;
  }

  .review-text {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-gray-800);
    margin: 0 0 1rem;
  }

  .review-meta {
    font-size: 0.82rem;
    color: var(--color-gray-500);
    margin: 0 0 0.85rem;
  }

  .card-footer {
    padding-top: 0.85rem;
    border-top: 1px solid var(--color-gray-200);
  }

  .business-name {
    font-family: var(--font-display);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  @media (max-width: 1024px) {
    .testimonials-masonry {
      columns: 2;
    }
  }

  @media (max-width: 768px) {
    .testimonials-section {
      padding: 3rem 1rem;
    }

    .section-title {
      font-size: 1.75rem;
    }

    .testimonials-masonry {
      columns: 1;
      max-width: 560px;
      margin: 0 auto;
    }
  }
</style>
