---
// WhyChooseUs — "The Crown Palace Shih Tzu Way" numbered principles + stats ribbon
const principles = [
  {
    num: '01',
    title: 'Health first, always',
    body: 'DNA-tested sire and dam, vet-verified hips and eyes, and a written two-year health guarantee on every pup that leaves our home.'
  },
  {
    num: '02',
    title: 'Raised in real life',
    body: 'Our shih tzus grow up with vacuum cleaners, grandkids, car rides, and doorbell chimes — the building blocks of a steady adult dog.'
  },
  {
    num: '03',
    title: 'Placed with intention',
    body: 'We take our time matching puppy to family. If a pup isn\'t right for your lifestyle, we\'ll tell you — and wait for the litter that is.'
  },
  {
    num: '04',
    title: 'A lifetime, not a transaction',
    body: 'Every family gets our cell number. Training questions at age two, vet advice at age eight — we answer them all.'
  }
];
---

<section class="way">
  <div class="way-inner">
    <header class="way-head">
      <div class="head-left">
        <span class="kicker">The Crown Palace Shih Tzu Way</span>
        <h2 class="way-title">
          Four promises we've<br>
          kept for over a <em>decade</em>.
        </h2>
      </div>
      <p class="head-right">
        What began as one litter is now a philosophy. These are the four commitments that shape every decision we make — from the parents we choose to the families we place with.
      </p>
    </header>

    <div class="principles">
      {principles.map((p) => (
        <article class="principle">
          <div class="num-wrap">
            <span class="num">{p.num}</span>
            <span class="num-rule"></span>
          </div>
          <h3 class="p-title">{p.title}</h3>
          <p class="p-body">{p.body}</p>
        </article>
      ))}
    </div>

    <div class="ribbon">
      <div class="ribbon-item">
        <span class="r-num">500+</span>
        <span class="r-label">Families Placed</span>
      </div>
      <div class="ribbon-sep"></div>
      <div class="ribbon-item">
        <span class="r-num">10<sup>yrs</sup></span>
        <span class="r-label">Raising Shih Tzus</span>
      </div>
      <div class="ribbon-sep"></div>
      <div class="ribbon-item">
        <span class="r-num">2<sup>yr</sup></span>
        <span class="r-label">Health Guarantee</span>
      </div>
      <div class="ribbon-sep"></div>
      <div class="ribbon-item">
        <span class="r-num">4.98<small>/5</small></span>
        <span class="r-label">Family Rating</span>
      </div>
    </div>
  </div>
</section>

<style>
  .way {
    background: var(--color-cream);
    padding: 6rem 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .way::before {
    content: '';
    position: absolute;
    top: -120px;
    right: -120px;
    width: 340px;
    height: 340px;
    background: radial-gradient(circle, rgba(212, 160, 85, 0.16), transparent 70%);
    pointer-events: none;
  }

  .way-inner {
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
  }

  .way-head {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 4rem;
    align-items: end;
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-gray-300);
  }

  .kicker {
    display: inline-block;
    font-family: var(--font-family);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: 1.2rem;
    position: relative;
    padding-left: 28px;
  }

  .kicker::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 20px;
    height: 1.5px;
    background: var(--color-secondary);
  }

  .way-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.6vw, 3.1rem);
    font-weight: 600;
    line-height: 1.1;
    color: var(--color-gray-900);
    margin: 0;
    letter-spacing: -0.02em;
  }

  .way-title em {
    font-style: italic;
    color: var(--color-primary);
    font-weight: 500;
  }

  .head-right {
    font-size: 1.02rem;
    line-height: 1.8;
    color: var(--color-gray-700);
    margin: 0 0 0.4rem;
  }

  .principles {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-bottom: 4.5rem;
  }

  .principle {
    padding: 0 1.75rem;
    position: relative;
  }

  .principle + .principle {
    border-left: 1px solid var(--color-gray-300);
  }

  .num-wrap {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-bottom: 1.25rem;
  }

  .num {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0;
  }

  .num-rule {
    flex: 1;
    height: 1px;
    background: var(--color-gray-400);
  }

  .p-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-gray-900);
    margin: 0 0 0.75rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .p-body {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-gray-700);
    margin: 0;
  }

  /* RIBBON */
  .ribbon {
    background: var(--color-primary);
    color: var(--color-cream);
    padding: 2.4rem 2rem;
    border-radius: 22px;
    display: flex;
    justify-content: space-around;
    align-items: center;
    gap: 1rem;
    position: relative;
    box-shadow: 0 24px 60px rgba(92, 51, 23, 0.28);
  }

  .ribbon::before {
    content: '';
    position: absolute;
    inset: 10px;
    border: 1px solid rgba(251, 245, 233, 0.15);
    border-radius: 16px;
    pointer-events: none;
  }

  .ribbon-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.3rem;
  }

  .r-num {
    font-family: var(--font-serif);
    font-size: 2.3rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-cream);
    letter-spacing: -0.015em;
  }

  .r-num sup {
    font-size: 0.8rem;
    opacity: 0.7;
    margin-left: 2px;
    font-style: italic;
  }

  .r-num small {
    font-size: 0.9rem;
    opacity: 0.7;
  }

  .r-label {
    font-family: var(--font-family);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(251, 245, 233, 0.75);
  }

  .ribbon-sep {
    width: 1px;
    height: 46px;
    background: rgba(251, 245, 233, 0.18);
  }

  @media (max-width: 1024px) {
    .principles { grid-template-columns: repeat(2, 1fr); gap: 2.5rem 0; }
    .principle { padding: 0 1.25rem; }
    .principle:nth-child(3) { border-left: 0; }
    .principle:nth-child(n+3) { padding-top: 2.5rem; border-top: 1px solid var(--color-gray-300); }
  }

  @media (max-width: 760px) {
    .way { padding: 4rem 1.2rem; }
    .way-head { grid-template-columns: 1fr; gap: 1.5rem; padding-bottom: 2rem; margin-bottom: 2.5rem; }
    .principles { grid-template-columns: 1fr; gap: 0; }
    .principle { border-left: 0 !important; padding: 1.75rem 0; border-top: 1px solid var(--color-gray-300); }
    .principle:first-child { border-top: 0; padding-top: 0; }
    .ribbon { flex-wrap: wrap; padding: 1.8rem 1.2rem; gap: 1.5rem; }
    .ribbon-sep { display: none; }
    .ribbon-item { flex: 1 1 40%; }
    .r-num { font-size: 1.8rem; }
  }
</style>
