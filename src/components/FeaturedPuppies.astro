---
// FeaturedPuppies component - displays featured Staffie puppies
const featuredPuppies = [
  { name: 'Alex', gender: 'Male', image: '/images/alex.webp' },
  { name: 'Ashley', gender: 'Female', image: '/images/ashley.webp' },
  { name: 'Cooper', gender: 'Male', image: '/images/cooper.webp' },
  { name: 'Gracie', gender: 'Female', image: '/images/gracie.webp' },
  { name: 'Thor', gender: 'Male', image: '/images/thor.webp' },
];
---

<section class="featured-section">
  <div class="section-header">
    <span class="section-kicker">Meet the Pups</span>
    <h2 class="section-title">
      Our <em>current</em> litter
    </h2>
    <p class="section-subtitle">Hand-raised Staffordshire Bull Terriers — each one already home with us, each one waiting for yours.</p>
  </div>

  <div class="puppies-container">
    <div class="puppies-grid">
      {featuredPuppies.map((puppy) => (
        <article class="puppy-card">
          <div class="card-image">
            <span class="rating-badge">
              <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
              5.0
            </span>
            <img src={puppy.image} alt={puppy.name} loading="lazy">
          </div>
          <div class="card-content">
            <h3 class="puppy-name">{puppy.name}</h3>
            <div class="card-stats">
              <span>Available</span>
              <span>Ready Now</span>
            </div>
            <button class="btn-contact" onclick={`openContactPopup('${puppy.name} (${puppy.gender})')`}>
              Inquire Now
            </button>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-section {
    display: block;
    font-family: var(--font-family, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif);
    background: var(--color-off-white);
    padding: 5rem 1.5rem;
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-kicker {
    display: inline-block;
    font-family: var(--font-family);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-secondary);
    margin-bottom: 0.9rem;
    position: relative;
    padding: 0 28px;
  }

  .section-kicker::before,
  .section-kicker::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 20px;
    height: 1.5px;
    background: var(--color-secondary);
  }

  .section-kicker::before { left: 0; }
  .section-kicker::after { right: 0; }

  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 3.4vw, 2.9rem);
    font-weight: 600;
    color: var(--color-gray-900);
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .section-title em {
    font-style: italic;
    color: var(--color-primary);
    font-weight: 500;
  }

  .section-subtitle {
    font-size: 1.02rem;
    color: var(--color-gray-600);
    margin: 0 auto;
    max-width: 560px;
    line-height: 1.7;
  }

  .puppies-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .puppies-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }

  .puppy-card {
    background: var(--color-white);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--color-gray-200);
    box-shadow: 0 2px 8px rgba(74, 43, 20, 0.05);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .puppy-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 40px rgba(74, 43, 20, 0.14);
  }

  .card-image {
    position: relative;
    height: 240px;
    overflow: hidden;
    background: var(--color-cream);
    padding: 0.5rem;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    border-radius: 12px;
  }

  .rating-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--color-cream);
    color: var(--color-primary);
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-family: var(--font-serif);
    font-size: 0.78rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    z-index: 1;
    box-shadow: 0 4px 12px rgba(74, 43, 20, 0.15);
  }

  .rating-badge svg {
    width: 12px;
    height: 12px;
    fill: var(--color-gold);
  }

  .card-content {
    padding: 1rem 1.1rem 1.25rem;
  }

  .puppy-name {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-gray-900);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }

  .card-stats {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-family);
    font-size: 0.78rem;
    color: var(--color-gray-600);
    margin-bottom: 0.85rem;
    letter-spacing: 0.03em;
  }

  .btn-contact {
    display: block;
    width: 100%;
    background: var(--color-primary);
    color: var(--color-cream);
    padding: 0.75rem;
    border: none;
    border-radius: 999px;
    font-family: var(--font-family);
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-contact:hover {
    background: var(--color-secondary);
    transform: translateY(-1px);
  }

  @media (max-width: 1200px) {
    .puppies-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .puppy-card:nth-child(5) {
      display: none;
    }

    .card-image {
      height: 200px;
    }
  }

  @media (max-width: 900px) {
    .puppies-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .puppy-card:nth-child(4),
    .puppy-card:nth-child(5) {
      display: none;
    }

    .card-image {
      height: 180px;
    }
  }

  @media (max-width: 600px) {
    .featured-section {
      padding: 2rem 1rem;
    }

    .section-title {
      font-size: 1.5rem;
    }

    .puppies-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .puppy-card:nth-child(3),
    .puppy-card:nth-child(4),
    .puppy-card:nth-child(5) {
      display: none;
    }

    .card-image {
      height: 160px;
    }

    .card-content {
      padding: 1rem 0.75rem;
    }

    .puppy-name {
      font-size: 1rem;
    }

    .current-price {
      font-size: 1.15rem;
    }
  }
</style>
